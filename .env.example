# Application Configuration
APP_NAME=College AI Chatbot System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=college_chatbot
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_POOL_SIZE=10

# Vector Database Configuration
VECTOR_DB_TYPE=chromadb
VECTOR_DB_PATH=./chroma_db
VECTOR_DB_COLLECTION=documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Authentication Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8
MFA_ENABLED=False

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_CONCURRENT_SESSIONS=5

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,doc,xlsx,xls,txt,png,jpg,jpeg
UPLOAD_DIR=./uploads
TEMP_DIR=./temp_files

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=eng

# AI/LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# External System Integration
ERP_API_URL=http://erp.college.edu/api
ERP_API_KEY=your-erp-api-key
NOTICE_BOARD_API_URL=http://notices.college.edu/api
NOTICE_BOARD_API_KEY=your-notice-api-key
ATTENDANCE_API_URL=http://attendance.college.edu/api
ATTENDANCE_API_KEY=your-attendance-api-key
LIBRARY_API_URL=http://library.college.edu/api
LIBRARY_API_KEY=your-library-api-key
CALENDAR_API_URL=http://calendar.college.edu/api
CALENDAR_API_KEY=your-calendar-api-key

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Notification Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@college.edu
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@college.edu
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-twilio-sid
SMS_AUTH_TOKEN=your-twilio-token
SMS_FROM_NUMBER=+1234567890

# Celery Configuration
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# Monitoring and Logging
ENABLE_METRICS=True
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1
ENCRYPTION_KEY=your-encryption-key-32-chars-min
SECURITY_AUDIT_ENABLED=True

# Kubernetes Configuration (for production)
K8S_NAMESPACE=chatbot-system
K8S_REPLICAS=3
K8S_CPU_REQUEST=500m
K8S_CPU_LIMIT=1000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=1Gi
